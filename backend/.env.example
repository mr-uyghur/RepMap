# SECURITY: If DJANGO_SECRET_KEY was ever exposed, generate a new one and rotate immediately.
# Generate with:
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# Set to False in production
DEBUG=True

# Comma-separated — restrict in production (e.g. yourdomain.com)
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated frontend origins — only used when DEBUG=False
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Leave blank to use SQLite (development only)
DATABASE_URL=

# Leave blank to use local memory cache
REDIS_URL=redis://localhost:6379

# No longer used for ZIP search (Google shut down /representatives in April 2025).
# ZIP lookup now uses the free Census Geocoder API — no key required.
GOOGLE_CIVIC_API_KEY=

# Required for AI summary tabs
ANTHROPIC_API_KEY=

# Auto-sync: refresh representative data automatically when stale (default: enabled, daily)
# Set AUTO_SYNC_ENABLED=false to disable background refresh (run sync_legislators manually instead)
AUTO_SYNC_ENABLED=true
AUTO_SYNC_STALE_HOURS=24

# District border data (run `python manage.py build_district_data` to generate local files)
# DISTRICT_DATA_DIR: override the default storage path (optional)
DISTRICT_DATA_DIR=
# DISTRICT_LIVE_FALLBACK: fall back to live Census API when local files are missing.
# Default true (development-friendly). Set false in production after running build_district_data.
DISTRICT_LIVE_FALLBACK=true
