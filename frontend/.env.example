# Development: point to local Django backend
VITE_API_BASE_URL=http://localhost:8000

# Production (Vercel): Leave UNSET — vercel.json rewrites proxy /api/* to Render.
# Set explicitly only if bypassing the Vercel proxy (direct-to-Render):
# VITE_API_BASE_URL=https://repmap-backend.onrender.com

VITE_MAPBOX_TOKEN=your-mapbox-token-here
