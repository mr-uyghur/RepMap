# Development: point to local Django backend
VITE_API_BASE_URL=http://localhost:8000

# Production (Railway): set to your backend Railway service URL.
# This is baked into the JS bundle at build time — set it in Railway's
# environment variables for the frontend service BEFORE the first deploy.
# VITE_API_BASE_URL=https://repmap-backend.up.railway.app

VITE_MAPBOX_TOKEN=your-mapbox-token-here
